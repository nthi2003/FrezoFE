{
  "name": "frezo-fe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "packages/types",
    "packages/utils",
    "packages/ui",
    "packages/erp",
    "packages/landing"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@frezo/erp",
    "dev:erp": "npm run dev --workspace=@frezo/erp",
    "dev:landing": "npm run dev --workspace=@frezo/landing",
    "build": "npm run build --workspace=@frezo/erp",
    "build:erp": "npm run build --workspace=@frezo/erp",
    "build:landing": "npm run build --workspace=@frezo/landing",
    "lint": "eslint packages/erp/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "npm run preview --workspace=@frezo/erp"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "typescript": "^5.0.2"
  }
}
